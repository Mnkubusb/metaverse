{
  "name": "metaverse",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "check-types": "turbo run check-types",
    "db:up": "docker compose up -d postgres",
    "db:down": "docker compose down",
    "db:generate": "pnpm --dir ./packages/db exec prisma generate",
    "db:migrate": "sh -ac 'set -a && . ./.env && set +a && pnpm --dir ./packages/db exec prisma migrate deploy'",
    "db:seed": "sh -ac 'set -a && . ./.env && set +a && pnpm --dir ./packages/db exec node scripts/seed.js'",
    "start:http": "pnpm db:generate && pnpm --dir ./apps/http run dev",
    "start:ws": "pnpm db:generate && pnpm --dir ./apps/ws run dev",
    "start:web": "pnpm --dir ./apps/web run start"
  },
  "dependencies": {
    "@prisma/client": "^6.19.1"
  },
  "devDependencies": {
    "prettier": "^3.5.3",
    "turbo": "^2.5.0",
    "typescript": "5.8.2"
  },
  "packageManager": "pnpm@9.0.0",
  "engines": {
    "node": ">=18"
  }
}
